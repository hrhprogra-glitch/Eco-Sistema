{
  "name": "eco-sistema",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k \"pnpm dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && node scripts/prepare-standalone.js && electron-builder"
  },
  "build": {
    "appId": "com.ecosistema.app",
    "productName": "Eco-Sistema",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "bcryptjs": "^3.0.3",
    "html2canvas-pro": "^2.2.3",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
